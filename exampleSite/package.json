{
  "name": "hugo-theme-tailwindcss-starter-example",
  "version": "1.0.0",
  "description": "Example site for hugo-theme-tailwindcss-starter (Tailwind CSS 4 + Skeleton UI)",
  "private": true,
  "scripts": {
    "hugo:dev": "hugo server -s . -DF --disableFastRender",
    "hugo": "hugo --gc --minify -s .",
    "dev": "npm run hugo:dev",
    "build": "npm run hugo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taocode/hugo-theme-tailwindcss-starter.git"
  },
  "keywords": [
    "hugo",
    "tailwindcss",
    "skeleton",
    "starter"
  ],
  "author": "taocode",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/taocode/hugo-theme-tailwindcss-starter/issues"
  },
  "homepage": "https://github.com/taocode/hugo-theme-tailwindcss-starter#readme",
  "devDependencies": {
    "@skeletonlabs/skeleton": "^4.15.2",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/typography": "^0.5.16",
    "tailwindcss": "^4.1.7"
  }
}
